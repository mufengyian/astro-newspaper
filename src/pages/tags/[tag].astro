---
import type { GetStaticPaths } from "astro";
import TagFeedPage from "../../components/TagFeedPage.astro";
import { getTagStaticPaths } from "../../utils/page-data";

export const getStaticPaths = (async () => getTagStaticPaths("zh-cn")) satisfies GetStaticPaths;
---

<TagFeedPage locale="zh-cn" tagName={Astro.props.tagName} posts={Astro.props.posts} />
