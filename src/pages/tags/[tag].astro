---
import type { GetStaticPaths } from "astro";
import TagPage from "../../components/pages/TagPage.astro";
import { createTagStaticPaths, type TagPageProps } from "../../utils/page-data";

export const getStaticPaths = createTagStaticPaths("zh-cn") satisfies GetStaticPaths;

const { tagName, posts } = Astro.props as TagPageProps;
---

<TagPage locale="zh-cn" tagName={tagName} posts={posts} />
