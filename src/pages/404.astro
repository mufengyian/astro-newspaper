---
import { siteConfig } from "../config";
import "../styles/global.css";
import { getDictionary, getHtmlLang } from "../utils/i18n";
import { withBase } from "../utils/routing";

const fallbackHref = withBase();
const locale = siteConfig.defaultLocale;
const dictionary = getDictionary(locale);

const backScript = String.raw`(() => {
	const fallbackHref = document.documentElement.dataset.fallbackHref || "/";
	const redirectDelay = Number(document.documentElement.dataset.redirectDelay || "2000");

	window.setTimeout(() => {
		if (window.history.length > 1 && document.referrer) {
			window.history.back();
			return;
		}

		window.location.replace(fallbackHref);
	}, redirectDelay);
})();`;
---

<!doctype html>
<html
	lang={getHtmlLang(locale)}
	data-fallback-href={fallbackHref}
	data-redirect-delay={String(siteConfig.notFound.redirectDelayMs)}
>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<meta name="description" content={dictionary.notFound.description} />
		<link rel="icon" type="image/svg+xml" href={withBase(siteConfig.assets.faviconSvg)} />
		<link rel="icon" href={withBase(siteConfig.assets.faviconIco)} />
		<title>{dictionary.notFound.title} | {siteConfig.title}</title>
		<script is:inline set:html={backScript}></script>
	</head>

	<body class:list={[`font-preset-${siteConfig.typography.preset}`, "system-page-body"]}>
		<main class="system-page system-page--404" aria-label={dictionary.notFound.ariaLabel}>
			<h1 class="system-page__code">404</h1>
			<p class="system-page__title">{dictionary.notFound.title}</p>
			<p class="system-page__description">{dictionary.notFound.description}</p>
			<p class="system-page__hint">{dictionary.notFound.redirectHint}</p>
		</main>
	</body>
</html>
