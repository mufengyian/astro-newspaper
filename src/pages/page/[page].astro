---
import type { GetStaticPaths } from "astro";
import PaginatedPostsPage from "../../components/pages/PaginatedPostsPage.astro";
import { createPaginatedFeedStaticPaths, type PaginatedPostFeedProps } from "../../utils/page-data";

export const getStaticPaths = createPaginatedFeedStaticPaths("zh-cn") satisfies GetStaticPaths;

const { currentPage, totalPages, pagePosts } = Astro.props as PaginatedPostFeedProps;
---

<PaginatedPostsPage
	locale="zh-cn"
	currentPage={currentPage}
	totalPages={totalPages}
	pagePosts={pagePosts}
/>
