---
import type { GetStaticPaths } from "astro";
import PaginatedFeedPage from "../../components/PaginatedFeedPage.astro";
import { getPaginationStaticPaths } from "../../utils/page-data";

export const getStaticPaths = (async () => getPaginationStaticPaths("zh-cn")) satisfies GetStaticPaths;
---

<PaginatedFeedPage
	locale="zh-cn"
	currentPage={Astro.props.currentPage}
	totalPages={Astro.props.totalPages}
	pagePosts={Astro.props.pagePosts}
/>
