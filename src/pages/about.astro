---
import PageHeader from "../components/PageHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { getDictionary } from "../utils/i18n";

const locale = "zh-cn" as const;
const dictionary = getDictionary(locale);
---

<MainLayout title={dictionary.about.title} description={dictionary.about.description}>
	<article class="post-single page-single">
		<PageHeader
			title={`${dictionary.about.title} ${dictionary.site.tagline}`}
			description={dictionary.about.intro}
			align="left"
		/>

		<div class="post-content">
			<p>{dictionary.about.body}</p>
			<p>{dictionary.site.authorBlurb}</p>

			<h2>{dictionary.about.principlesTitle}</h2>
			<ul>
				{dictionary.principles.map((principle) => (
					<li>
						<strong>{principle.title}</strong>：{principle.description}
					</li>
				))}
			</ul>

			<h2>{dictionary.about.capabilitiesTitle}</h2>
			<ul>
				{dictionary.site.capabilities.map((capability) => (
					<li>{capability}</li>
				))}
			</ul>
		</div>
	</article>
</MainLayout>
