---
import { getCollection } from "astro:content";
import PostFeed from "../../components/PostFeed.astro";
import { siteConfig } from "../../config";
import MainLayout from "../../layouts/MainLayout.astro";
import { getDictionary } from "../../utils/i18n";
import { getHomePermalink, getLocalizedPath, getRssPermalink } from "../../utils/routing";
import { getHomePosts, getPageItems, getSortedPosts, getTotalPages } from "../../utils/posts";

const locale = "en" as const;
const dictionary = getDictionary(locale);
const posts = getSortedPosts(await getCollection("posts"), locale);
const homePosts = getHomePosts(posts, siteConfig.featuredCount);
const totalPages = getTotalPages(homePosts.length, siteConfig.postsPerPage);
const pagePosts = getPageItems(homePosts, 1, siteConfig.postsPerPage);
---

<MainLayout bodyClass="list home">
	<section id="hero" class="home-info">
		<div class="home-info__inner">
			<div class="home-info__title-row">
				<h1>{siteConfig.title}</h1>
				<a class="home-info__rss" href={getRssPermalink(locale)} aria-label="RSS Feed" title="RSS Feed">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="M5 19a1 1 0 1 0 0-2a1 1 0 0 0 0 2Zm-1-8a9 9 0 0 1 9 9h2C15 14.477 9.523 9 3 9v2Zm0-7a16 16 0 0 1 16 16h2C22 10.059 13.941 2 4 2v2Z"
							fill="currentColor"
						/>
					</svg>
					<span class="sr-only">RSS Feed</span>
				</a>
			</div>

			<p class="home-info__lead">Welcome to the demo page of {siteConfig.title}.</p>

			<ul class="home-info__list">
				{dictionary.principles.map((principle) => (
					<li>
						<strong>{principle.title}</strong>: {principle.description}
					</li>
				))}
			</ul>

			<p class="home-info__secondary">
				Read the posts or check
				<a href={`${siteConfig.repositoryUrl}#readme`} target="_blank" rel="noreferrer">README</a>
				for more information.
			</p>

			{
				siteConfig.socialLinks.length > 0 && (
					<div class="home-info__links-row">
						<div class="home-info__links-label">Social Links:</div>
						<div class="home-info__links">
							{siteConfig.socialLinks.map((link) => (
								<a href={link.href} target="_blank" rel="noreferrer" aria-label={link.label} title={link.label}>
									{
										link.label === "GitHub" ? (
											<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
												<path
													d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2c2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2a4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0c-2.4-1.6-3.5-1.3-3.5-1.3a4.2 4.2 0 0 0-.1 3.2a4.6 4.6 0 0 0-1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6.6-.6 1.2-.5 2v3.5"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
												/>
											</svg>
										) : link.label === "X" ? (
											<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
												<path
													d="M4 4l11.733 16H20L8.267 4z"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
												/>
												<path
													d="M4 20l6.768-6.768m2.46-2.46L20 4"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
												/>
											</svg>
										) : link.label === "LinkedIn" ? (
											<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
												<path d="M8 11v5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
												<path d="M8 8v.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
												<path d="M12 16v-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
												<path d="M16 16v-3a2 2 0 1 0-4 0" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
												<path d="M3 7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
											</svg>
										) : (
											<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
												<path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
												<path d="M3 7l9 6l9-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
											</svg>
										)
									}
									<span class="sr-only">{link.label}</span>
								</a>
							))}
						</div>
					</div>
				)
			}
		</div>
	</section>

	<PostFeed
		posts={pagePosts}
		currentPage={1}
		totalPages={totalPages}
		firstPageUrl={getHomePermalink(locale)}
		pageUrlPattern={getLocalizedPath(locale, "page/{page}")}
	/>
</MainLayout>
