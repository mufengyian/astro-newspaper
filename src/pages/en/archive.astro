---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { formatDate } from "../../utils/date";
import { getDictionary } from "../../utils/i18n";
import { getPostPermalink, getReadingMinutes, getSortedPosts, groupPostsByYear } from "../../utils/posts";

const locale = "en" as const;
const dictionary = getDictionary(locale);
const posts = getSortedPosts(await getCollection("posts"), locale);
const groupedPosts = groupPostsByYear(posts);
---

<MainLayout title={dictionary.archive.title} description={dictionary.archive.description} bodyClass="list">
	<header class="page-header">
		<h1>{dictionary.archive.title}</h1>
		<p>{dictionary.archive.description}</p>
	</header>

	<div class="archive-posts">
		{groupedPosts.map(([year, entries]) => (
			<section class="archive-year">
				<h2>
					{year}
					<span class="archive-count">&nbsp;&nbsp;{dictionary.archive.yearCount(entries.length)}</span>
				</h2>

				{entries.map((post) => (
					<article class="archive-entry">
						<h3 class="archive-entry-title">
							<a href={getPostPermalink(locale, post)} data-astro-prefetch="hover">
								{post.data.title}
							</a>
						</h3>
						<div class="archive-meta">
							<time>{formatDate(post.data.publishDate, locale)}</time>
							<span aria-hidden="true">&middot;</span>
							<span>{dictionary.reading.minutes(getReadingMinutes(post))}</span>
							{post.data.category && (
								<>
									<span aria-hidden="true">&middot;</span>
									<span>{post.data.category}</span>
								</>
							)}
						</div>
					</article>
				))}
			</section>
		))}
	</div>
</MainLayout>
