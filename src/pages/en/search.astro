---
import { getCollection } from "astro:content";
import SearchPanel from "../../components/SearchPanel.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { getDictionary } from "../../utils/i18n";
import { getArchivePermalink, getTagsPermalink } from "../../utils/routing";
import { getSortedPosts, getTagIndex, getTagPermalink } from "../../utils/posts";

const locale = "en" as const;
const dictionary = getDictionary(locale);
const posts = getSortedPosts(await getCollection("posts"), locale);
const topics = getTagIndex(posts).slice(0, 8).map((tag) => ({
	label: tag.name,
	href: getTagPermalink(locale, tag.slug),
	count: tag.count,
}));
const quickLinks = [
	{ label: dictionary.search.browseArchive, href: getArchivePermalink(locale) },
	{ label: dictionary.search.browseTags, href: getTagsPermalink(locale) },
];
---

<MainLayout title={dictionary.search.title} description={dictionary.search.description} bodyClass="list">
	<section class="search-shell">
		<header class="search-page-header">
			<h1>
				<span>{dictionary.search.title}</span>
				<span class="search-page-header__icon" aria-hidden="true">⌕</span>
			</h1>
			<p>{dictionary.search.description}</p>
		</header>

		<SearchPanel indexedCount={posts.length} quickLinks={quickLinks} topics={topics} />
	</section>
</MainLayout>
