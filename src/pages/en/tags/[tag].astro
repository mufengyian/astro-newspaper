---
import type { GetStaticPaths } from "astro";
import TagFeedPage from "../../../components/TagFeedPage.astro";
import { getTagStaticPaths } from "../../../utils/page-data";

export const getStaticPaths = (async () => getTagStaticPaths("en")) satisfies GetStaticPaths;
---

