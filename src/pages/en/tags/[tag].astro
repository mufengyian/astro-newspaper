---
import type { GetStaticPaths } from "astro";
import TagPage from "../../../components/pages/TagPage.astro";
import { createTagStaticPaths, type TagPageProps } from "../../../utils/page-data";

export const getStaticPaths = createTagStaticPaths("en") satisfies GetStaticPaths;

const { tagName, posts } = Astro.props as TagPageProps;
---

<TagPage locale="en" tagName={tagName} posts={posts} />
