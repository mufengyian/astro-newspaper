---
import type { GetStaticPaths } from "astro";
import PostPage from "../../../components/pages/PostPage.astro";
import { createPostStaticPaths, type PostRouteProps } from "../../../utils/page-data";

export const getStaticPaths = createPostStaticPaths("en") satisfies GetStaticPaths;

const { post, posts } = Astro.props as PostRouteProps;
---

<PostPage post={post} posts={posts} />
