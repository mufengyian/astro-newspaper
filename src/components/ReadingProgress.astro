<div class="reading-progress" aria-hidden="true">
	<span class="reading-progress__bar" data-reading-progress></span>
</div>

<script>
	(() => {
		let activeBar: HTMLElement | null = null;
		let ticking = false;

		const update = () => {
			if (!activeBar || !document.body.contains(activeBar)) {
				activeBar = document.querySelector<HTMLElement>("[data-reading-progress]");
			}

			if (!activeBar) {
				ticking = false;
				return;
			}

			const container =
				document.querySelector<HTMLElement>("[data-reading-container]") ?? document.documentElement;
			const rect = container.getBoundingClientRect();
			const start = window.scrollY + rect.top - 120;
			const end = start + container.offsetHeight - window.innerHeight * 0.4;
			const distance = Math.max(1, end - start);
			const progress = Math.min(1, Math.max(0, (window.scrollY - start) / distance));
			activeBar.style.transform = `scaleX(${progress})`;
			ticking = false;
		};

		const requestUpdate = () => {
			if (ticking) return;
			ticking = true;
			window.requestAnimationFrame(update);
		};

		const refresh = () => {
			activeBar = document.querySelector<HTMLElement>("[data-reading-progress]");
			requestUpdate();
		};

		window.__newspaperReadingProgressRefresh = refresh;

		if (!window.__newspaperReadingProgressBound) {
			window.__newspaperReadingProgressBound = true;
			window.addEventListener("scroll", requestUpdate, { passive: true });
			window.addEventListener("resize", requestUpdate);
			document.addEventListener("astro:page-load", refresh);
		}

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", refresh, { once: true });
		} else {
			refresh();
		}
	})();
</script>
