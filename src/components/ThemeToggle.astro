---
import { themeConfig } from "../config";
import { getDictionary, resolveLocale } from "../utils/i18n";

const locale = resolveLocale(Astro.currentLocale);
const dictionary = getDictionary(locale);
---

<button
	id="theme-toggle"
	type="button"
	data-theme-toggle
	data-theme-default={themeConfig.defaultPreference}
	data-theme-label={dictionary.theme.label}
	data-theme-system={dictionary.theme.system}
	data-theme-light={dictionary.theme.light}
	data-theme-dark={dictionary.theme.dark}
	aria-label={dictionary.theme.label}
	title={dictionary.theme.label}
	transition:persist
>
	<svg
		id="system"
		xmlns="http://www.w3.org/2000/svg"
		width="18"
		height="18"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<rect x="3" y="4" width="18" height="12" rx="2"></rect>
		<path d="M8 20h8"></path>
		<path d="M12 16v4"></path>
	</svg>
	<svg
		id="moon"
		xmlns="http://www.w3.org/2000/svg"
		width="18"
		height="18"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
	</svg>
	<svg
		id="sun"
		xmlns="http://www.w3.org/2000/svg"
		width="18"
		height="18"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<circle cx="12" cy="12" r="5"></circle>
		<line x1="12" y1="1" x2="12" y2="3"></line>
		<line x1="12" y1="21" x2="12" y2="23"></line>
		<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
		<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
		<line x1="1" y1="12" x2="3" y2="12"></line>
		<line x1="21" y1="12" x2="23" y2="12"></line>
		<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
		<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
	</svg>
</button>

<script>
	const preferences = ["system", "light", "dark"];

	function nextTheme(current: string) {
		const index = preferences.indexOf(current);
		return preferences[(index + 1 + preferences.length) % preferences.length];
	}

	function getThemeLabel(button: HTMLButtonElement, state: string) {
		if (state === "light") return button.dataset.themeLight || "Light mode";
		if (state === "dark") return button.dataset.themeDark || "Dark mode";
		return button.dataset.themeSystem || "System mode";
	}

	function updateButtons() {
		document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((button) => {
			const defaultTheme = button.dataset.themeDefault || "system";
			const state =
				window.__getNewspaperTheme?.() ||
				document.documentElement.dataset.themePreference ||
				defaultTheme;
			const currentLabel = getThemeLabel(button, state);
			const nextLabel = getThemeLabel(button, nextTheme(state));
			const baseLabel = button.dataset.themeLabel || "Switch theme";
			button.setAttribute("aria-label", `${baseLabel}. ${currentLabel}. ${nextLabel}.`);
			button.setAttribute("title", `${currentLabel} → ${nextLabel}`);
			button.dataset.themeState = state;
		});
	}

	function initThemeToggle() {
		window.__applyNewspaperTheme?.();

		document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((button) => {
			if (button.dataset.bound === "true") return;
			button.dataset.bound = "true";
			button.addEventListener("click", () => {
				const defaultTheme = button.dataset.themeDefault || "system";
				const current =
					window.__getNewspaperTheme?.() ||
					document.documentElement.dataset.themePreference ||
					defaultTheme;
				window.__setNewspaperTheme?.(nextTheme(current));
				updateButtons();
			});
		});

		updateButtons();
	}

	if (!window.__newspaperThemeToggleBound) {
		window.__newspaperThemeToggleBound = true;
		document.addEventListener("astro:page-load", initThemeToggle);
	}

	if (!window.__newspaperThemeChangeBound) {
		window.__newspaperThemeChangeBound = true;
		window.addEventListener("newspaper:themechange", updateButtons);
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initThemeToggle, { once: true });
	} else {
		initThemeToggle();
	}
</script>

<style>
	button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		margin: 0;
		cursor: pointer;
		border-radius: 0;
		background: transparent;
		box-shadow: none;
		border: 0;
		padding: 0;
	}

	button svg {
		display: none;
	}

	button #system {
		display: block;
	}

	:global([data-theme-preference="light"]) button #sun,
	:global([data-theme-preference="dark"]) button #moon {
		display: block;
	}

	:global([data-theme-preference="light"]) button #system,
	:global([data-theme-preference="light"]) button #moon,
	:global([data-theme-preference="dark"]) button #system,
	:global([data-theme-preference="dark"]) button #sun {
		display: none;
	}
</style>
