---
import { Picture } from "astro:assets";
import { siteConfig } from "../config";
import { getDictionary, resolveLocale } from "../utils/i18n";
import { getPostPermalink, type PostEntry } from "../utils/posts";
import PostMeta from "./PostMeta.astro";

interface Props {
	post: PostEntry;
	compact?: boolean;
}

const locale = resolveLocale(Astro.currentLocale);
const dictionary = getDictionary(locale);
const { post, compact = false } = Astro.props;
const href = getPostPermalink(locale, post);
const entryLabel = dictionary.post.openLabel(post.data.title);
const listingCover = siteConfig.media.listingCover;
---

<article class:list={["post-entry", compact && "post-entry--compact"]}>
	<a class="post-entry__body" href={href} aria-label={entryLabel} data-astro-prefetch="hover">
		{!compact && post.data.cover && (
			<div class="entry-cover">
				<Picture
					src={post.data.cover}
					alt={post.data.coverAlt ?? post.data.title}
					widths={[...listingCover.widths]}
					sizes={listingCover.sizes}
					formats={[...listingCover.formats]}
					quality={listingCover.quality}
					layout="constrained"
					loading="lazy"
					decoding="async"
				/>
			</div>
		)}

		<div class="post-entry__content">
			<header class="entry-header">
				<h2 transition:name={`title-${post.id}`}>{post.data.title}</h2>
			</header>
			<div class="entry-content">
				<p>{post.data.excerpt}</p>
			</div>
			<footer class="entry-footer">
				<PostMeta post={post} />
			</footer>
		</div>
	</a>
</article>
