---
import { formatDate } from "../utils/date";
import { getDictionary, resolveLocale } from "../utils/i18n";
import { getPostPermalink, type PostEntry } from "../utils/posts";

interface Props {
	posts: PostEntry[];
}

const locale = resolveLocale(Astro.currentLocale);
const dictionary = getDictionary(locale);
const { posts } = Astro.props;
---

{
	posts.length > 0 && (
		<section class="related-posts">
			<header class="page-header">
				<h2>{dictionary.post.relatedPosts}</h2>
			</header>

			<div class="related-posts__grid">
				{posts.map((post) => (
					<article class="post-entry">
						<header class="entry-header">
							<h3>
								<a href={getPostPermalink(locale, post)} data-astro-prefetch="hover">
									{post.data.title}
								</a>
							</h3>
						</header>
						<div class="entry-content">
							<p>{post.data.excerpt}</p>
						</div>
						<footer class="entry-footer">
							<span>{formatDate(post.data.publishDate, locale)}</span>
						</footer>
						<a
							class="entry-link"
							href={getPostPermalink(locale, post)}
							aria-label={dictionary.post.openRelatedLabel(post.data.title)}
							data-astro-prefetch="hover"
						></a>
					</article>
				))}
			</div>
		</section>
	)
}
