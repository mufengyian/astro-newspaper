---
import { getDictionary, resolveLocale } from "../utils/i18n";
import type { PostEntry } from "../utils/posts";
import PageHeader from "./PageHeader.astro";
import PostCard from "./PostCard.astro";

interface Props {
	posts: PostEntry[];
}

const locale = resolveLocale(Astro.currentLocale);
const dictionary = getDictionary(locale);
const { posts } = Astro.props;
---

{
	posts.length > 0 && (
		<section class="related-posts">
			<PageHeader title={dictionary.post.relatedPosts} level="h2" align="start" class="page-header--section" />

			<div class="related-posts__grid posts-grid posts-grid--narrow">
				{posts.map((post) => (
					<PostCard post={post} compact />
				))}
			</div>
		</section>
	)
}
