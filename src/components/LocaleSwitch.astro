---
import { getDictionary, resolveLocale } from "../utils/i18n";
import { getLocaleAlternates } from "../utils/routing";
import { translationKeyStore } from "../utils/context";

const translationKey = translationKeyStore.get();
const locale = resolveLocale(Astro.currentLocale);
const dictionary = getDictionary(locale);
const alternateLocales = await getLocaleAlternates(Astro.url.pathname, translationKey);
---

<div class="locale-switch" aria-label={dictionary.langSwitchLabel}>
	{alternateLocales.map(({ locale: alternateLocale, relativeUrl }) => (
		alternateLocale === locale ? (
			<span class="locale-switch__current" aria-current="page">
				{alternateLocale === "zh-cn" ? "Zh" : "En"}
			</span>
		) : (
			<a class="locale-switch__link" href={relativeUrl} data-astro-prefetch="hover">
				{alternateLocale === "zh-cn" ? "Zh" : "En"}
			</a>
		)
	))}
</div>
