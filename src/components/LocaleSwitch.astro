---
import { getDictionary, resolveLocale } from "../utils/i18n";
import { getLocaleAlternates } from "../utils/routing";

const locale = resolveLocale(Astro.currentLocale);
const dictionary = getDictionary(locale);
const alternateLocales = await getLocaleAlternates(Astro.url.pathname, locale);
---

<nav class="locale-switch" aria-label={dictionary.langSwitchLabel}>
	{alternateLocales.map(({ locale: alternateLocale, relativeUrl }) => (
		alternateLocale === locale ? (
			<span class="locale-switch__current" aria-current="page">
				{alternateLocale === "zh-cn" ? "ZH" : "EN"}
			</span>
		) : (
			relativeUrl ? (
				<a class="locale-switch__link" href={relativeUrl} data-astro-prefetch="hover">
					{alternateLocale === "zh-cn" ? "ZH" : "EN"}
				</a>
			) : (
				<span class="locale-switch__link" aria-disabled="true">
					{alternateLocale === "zh-cn" ? "ZH" : "EN"}
				</span>
			)
		)
	))}
</nav>
