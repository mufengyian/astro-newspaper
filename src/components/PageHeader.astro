---
interface Props {
	title: string;
	description?: string;
	eyebrow?: string;
	level?: "h1" | "h2";
	align?: "start" | "center";
	class?: string;
}

const { title, description, eyebrow, level = "h1", align = "center", class: className } = Astro.props;
const HeadingTag = level;
---

<header class:list={["page-header", `page-header--${align}`, className]}>
	{eyebrow && <p class="page-header__eyebrow">{eyebrow}</p>}
	<HeadingTag>{title}</HeadingTag>
	{description && <p class="page-header__description">{description}</p>}
</header>
