---
import { siteConfig } from "../config";
import type { SiteLocale } from "../utils/i18n";
import { getDictionary } from "../utils/i18n";
import {
	getArchivePermalink,
	getRssPagePermalink,
	getSearchPermalink,
} from "../utils/routing";
import SocialIcon from "./SocialIcon.astro";

interface Props {
	locale: SiteLocale;
	postCount: number;
}

const { locale, postCount } = Astro.props;
const dictionary = getDictionary(locale);
const stats = [
	dictionary.home.postCount(postCount),
	dictionary.home.featuredCount(siteConfig.posts.featuredCount),
	dictionary.home.languageCount(siteConfig.locales.length),
];
---

<section class="hero">
	<div class="hero__copy">
		<p class="hero__eyebrow">{dictionary.home.eyebrow}</p>
		<h1>{dictionary.home.title}</h1>
		<p class="hero__description">{dictionary.home.description}</p>

		<ul class="hero__stats" aria-label={dictionary.home.feedTitle}>
			{stats.map((item) => (
				<li>{item}</li>
			))}
		</ul>

		<div class="hero__actions">
			<a class="button button--primary" href={getArchivePermalink(locale)} data-astro-prefetch="hover">
				{dictionary.home.browseArchive}
			</a>
			<a class="button" href={getSearchPermalink(locale)} data-astro-prefetch="hover">
				{dictionary.home.startSearch}
			</a>
			<a class="button button--subtle" href={siteConfig.repositoryUrl} target="_blank" rel="noreferrer">
				{dictionary.home.viewSource}
			</a>
			<a class="button button--subtle" href={getRssPagePermalink(locale)} data-astro-prefetch="hover">
				{dictionary.home.readRss}
			</a>
		</div>

		<p class="hero__hint">{dictionary.home.repositoryHint}</p>

		{
			siteConfig.socialLinks.length > 0 && (
				<div class="hero__socials">
					<span class="hero__socials-label">{dictionary.common.socialLinksLabel}</span>
					<div class="hero__socials-list">
						{siteConfig.socialLinks.map((link) => (
							<a
								class="social-link"
								href={link.href}
								target="_blank"
								rel="noreferrer"
								aria-label={link.label}
								title={link.label}
							>
								<SocialIcon platform={link.label} />
								<span class="sr-only">{link.label}</span>
							</a>
						))}
					</div>
				</div>
			)
		}
	</div>

	<div class="hero__panel surface-card">
		<div class="hero__panel-block">
			<p class="hero__panel-title">{dictionary.about.principlesTitle}</p>
			<ul class="hero__principles">
				{dictionary.principles.map((principle) => (
					<li>
						<strong>{principle.title}</strong>
						<span>{principle.description}</span>
					</li>
				))}
			</ul>
		</div>

		<div class="hero__panel-block">
			<p class="hero__panel-title">{dictionary.about.capabilitiesTitle}</p>
			<ul class="capability-list">
				{dictionary.site.capabilities.map((capability) => (
					<li>{capability}</li>
				))}
			</ul>
		</div>
	</div>
</section>
