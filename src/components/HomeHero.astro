---
import { siteConfig } from "../config";
import type { SiteLocale } from "../utils/i18n";
import { getDictionary } from "../utils/i18n";
import { getPostPermalink, type PostEntry } from "../utils/posts";
import {
	getArchivePermalink,
	getRssPagePermalink,
	getSearchPermalink,
} from "../utils/routing";
import PostMeta from "./PostMeta.astro";
import TagPill from "./TagPill.astro";

type TagSummary = {
	name: string;
	slug: string;
	count: number;
};

interface Props {
	locale: SiteLocale;
	posts: PostEntry[];
	popularTags: TagSummary[];
}

const { locale, posts, popularTags } = Astro.props as Props;
const dictionary = getDictionary(locale);
const latestPost = posts[0];
const topTags = popularTags.slice(0, 5);
---

<section class="home-hero">
	<div class="home-hero__content">
		<p class="home-hero__eyebrow">{dictionary.home.eyebrow}</p>
		<h1>{dictionary.home.title}</h1>
		<p class="home-hero__description">{dictionary.home.description}</p>

		<div class="button-row home-hero__actions">
			<a class="button button--primary" href={getArchivePermalink(locale)} data-astro-prefetch="hover">
				{dictionary.home.browseArchive}
			</a>
			<a class="button" href={getSearchPermalink(locale)} data-astro-prefetch="hover">
				{dictionary.home.startSearch}
			</a>
			<a class="button" href={getRssPagePermalink(locale)} data-astro-prefetch="hover">RSS</a>
		</div>

		<div class="home-hero__summary">
			<p>{dictionary.home.postCount(posts.length)}</p>
			<p>{dictionary.home.tagCount(popularTags.length)}</p>
			<p>{dictionary.home.capabilityCount(siteConfig.capabilities.length)}</p>
		</div>

		<dl class="home-hero__stats" aria-label={dictionary.home.feedTitle}>
			<div>
				<dt>{posts.length}</dt>
				<dd>{dictionary.home.stats.posts}</dd>
			</div>
			<div>
				<dt>{popularTags.length}</dt>
				<dd>{dictionary.home.stats.tags}</dd>
			</div>
			<div>
				<dt>{siteConfig.capabilities.length}</dt>
				<dd>{dictionary.home.stats.capabilities}</dd>
			</div>
		</dl>
	</div>

	<div class="home-hero__panel">
		{latestPost && (
			<article class="home-hero__panel-card home-hero__panel-card--primary">
				<p class="home-hero__panel-label">{dictionary.home.latestLabel}</p>
				<h2>
					<a href={getPostPermalink(locale, latestPost)} data-astro-prefetch="hover">
						{latestPost.data.title}
					</a>
				</h2>
				<p class="home-hero__panel-excerpt">{latestPost.data.excerpt}</p>
				<PostMeta post={latestPost} />
				<div class="home-hero__panel-actions">
					<a class="button" href={getPostPermalink(locale, latestPost)} data-astro-prefetch="hover">
						{dictionary.home.readLatest}
					</a>
				</div>
			</article>
		)}

		{topTags.length > 0 && (
			<section class="home-hero__panel-card">
				<p class="home-hero__panel-label">{dictionary.home.popularTags}</p>
				<div class="home-hero__topics">
					{topTags.map((tag) => (
						<TagPill tag={tag.name} count={tag.count} />
					))}
				</div>
			</section>
		)}
	</div>
</section>
