	<p class="small footer__small">
		&copy; {footer.copyrightYear} <a href={footer.owner.href} {...ownerLinkAttributes}>{footer.owner.label}</a>
	</p>

	{
		footer.icp.enabled && (
			<p class="small footer__small footer__small--icp">
				<svg class="icon icon-20 footer__icon" aria-hidden="true">
					<use xlink:href="#ICP"></use>
				</svg>
				<a href={footer.icp.href} target="_blank" rel="noreferrer">{footer.icp.label}</a>
			</p>
		)
	}

	<p class="small footer__small">
		{footer.labels.poweredBy}{" "}
		<a href={footer.poweredBy.href} {...poweredByLinkAttributes}>{footer.poweredBy.label}</a>{" "}
		<span aria-hidden="true">※</span>{" "}
		{footer.labels.themeIs}{" "}
		<a href={footer.theme.href} {...themeLinkAttributes}>{footer.theme.label}</a>
	</p>
</footer>
