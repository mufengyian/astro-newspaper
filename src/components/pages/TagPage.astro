---
import MainLayout from "../../layouts/MainLayout.astro";
import { siteConfig } from "../../config";
import { getDictionary, type SiteLocale } from "../../utils/i18n";
import type { TagPageProps } from "../../utils/page-data";
import PageHeader from "../PageHeader.astro";
import PostFeed from "../PostFeed.astro";

interface Props extends TagPageProps {
	locale: SiteLocale;
}

const { locale, tagName, posts } = Astro.props;
const dictionary = getDictionary(locale);
---

<MainLayout
	title={`${dictionary.tags.title} · ${tagName}`}
	description={dictionary.tags.pageDescription(tagName)}
	bodyClass="list"
>
	<PageHeader
		title={`#${tagName}`}
		description={dictionary.tags.relatedDescription}
		eyebrow={siteConfig.title}
	/>

	<PostFeed posts={posts} />
</MainLayout>
