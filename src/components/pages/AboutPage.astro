---
import { getAboutContent } from "../../config/about";
import { siteConfig } from "../../config";
import MainLayout from "../../layouts/MainLayout.astro";
import { getDictionary, type SiteLocale } from "../../utils/i18n";
import PageHeader from "../PageHeader.astro";

interface Props {
	locale: SiteLocale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const aboutContent = getAboutContent(locale);
---

<MainLayout title={dictionary.about.title} description={dictionary.about.description} bodyClass="list">
	<section class="about-page">
		<PageHeader
			title={`${dictionary.about.title} ${siteConfig.title}`}
			description={aboutContent.lead}
			eyebrow={dictionary.site.tagline}
		/>

		<div class="about-page__body">
			{aboutContent.sections.map((section) => (
				<section class="about-section">
					<h2>{section.title}</h2>
					{section.paragraphs.map((paragraph) => (
						<p>{paragraph}</p>
					))}
					{
						section.list && (
							<ul class="feature-list">
								{section.list.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						)
					}
				</section>
			))}
		</div>
	</section>
</MainLayout>
