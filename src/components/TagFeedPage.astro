---
import type { SiteLocale } from "../utils/i18n";
import { getDictionary } from "../utils/i18n";
import type { PostEntry } from "../utils/posts";
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "./PageHeader.astro";
import PostFeed from "./PostFeed.astro";

interface Props {
	locale: SiteLocale;
	tagName: string;
	posts: PostEntry[];
}

const { locale, tagName, posts } = Astro.props;
const dictionary = getDictionary(locale);
---

<MainLayout
	title={`${dictionary.tags.title} · ${tagName}`}
	description={dictionary.tags.pageDescription(tagName)}
	bodyClass="list"
>
	<PageHeader title={`#${tagName}`} description={dictionary.tags.relatedDescription} />
	<PostFeed posts={posts} />
</MainLayout>
