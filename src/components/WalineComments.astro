---
import { hasWalineServerUrl, siteConfig } from "../config";
import { getDictionary, resolveLocale } from "../utils/i18n";
import { stripBasePath } from "../utils/routing";

const locale = resolveLocale(Astro.currentLocale);
const dictionary = getDictionary(locale);
const canRenderWaline = hasWalineServerUrl();
const commentsPath = stripBasePath(Astro.url.pathname).replace(/\/$/, "") || "/";
const walineLang = locale === "en" ? "en" : "zh-CN";
const walineMeta = siteConfig.comments.meta.join(",");
const walineRequiredMeta = siteConfig.comments.requiredMeta.join(",");
---

{
	canRenderWaline && (
		<section class="comments-section" aria-labelledby="comments-title">
			<div class="comments-section__header">
				<h2 id="comments-title">{dictionary.comments.title}</h2>
				<p>{dictionary.comments.description}</p>
			</div>

			<div
				class="comments-shell"
				data-waline-root={canRenderWaline ? "true" : undefined}
				data-waline-server={siteConfig.comments.serverURL}
				data-waline-path={commentsPath}
				data-waline-lang={walineLang}
				data-waline-meta={walineMeta}
				data-waline-required-meta={walineRequiredMeta}
				data-waline-login={siteConfig.comments.login}
				data-waline-comment-sorting={siteConfig.comments.commentSorting}
				data-waline-page-size={String(siteConfig.comments.pageSize)}
				data-waline-reaction={siteConfig.comments.reaction ? "true" : "false"}
			>
				<div class="comments-shell__inner" data-waline-thread></div>
			</div>
		</section>
	)
}

{
	canRenderWaline && (
		<script is:inline>
			(() => {
				const destroyWaline = () => {
					if (window.__newspaperWaline?.destroy) {
						window.__newspaperWaline.destroy();
					}
					window.__newspaperWaline = null;
				};

				const mountWaline = async () => {
					destroyWaline();

					const root = document.querySelector("[data-waline-root='true']");
					if (!(root instanceof HTMLElement)) {
						return;
					}

					const thread = root.querySelector("[data-waline-thread]");
					if (!(thread instanceof HTMLElement)) {
						return;
					}

					const { init } = await import("@waline/client");
					window.__newspaperWaline = init({
						el: thread,
						serverURL: root.dataset.walineServer || "",
						path: root.dataset.walinePath || window.location.pathname,
						lang: root.dataset.walineLang || "zh-CN",
						dark: "html[data-theme='dark']",
						meta: (root.dataset.walineMeta || "nick,mail,link").split(","),
						requiredMeta: (root.dataset.walineRequiredMeta || "nick,mail").split(","),
						login: root.dataset.walineLogin || "enable",
						commentSorting: root.dataset.walineCommentSorting || "latest",
						pageSize: Number(root.dataset.walinePageSize || "10"),
						reaction: root.dataset.walineReaction === "true",
					});
				};

				if (!window.__newspaperWalineBound) {
					window.__newspaperWalineBound = true;
					document.addEventListener("astro:before-swap", destroyWaline);
					document.addEventListener("astro:page-load", () => {
						void mountWaline();
					});
				}

				if (document.readyState === "loading") {
					document.addEventListener(
						"DOMContentLoaded",
						() => {
							void mountWaline();
						},
						{ once: true },
					);
				} else {
					void mountWaline();
				}
			})();
		</script>
	)
}
