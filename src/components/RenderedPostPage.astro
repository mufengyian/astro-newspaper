---
import { render } from "astro:content";
import PostLayout from "../layouts/PostLayout.astro";
import { getPostPageData } from "../utils/page-data";
import type { PostEntry } from "../utils/posts";

interface Props {
	post: PostEntry;
	posts: PostEntry[];
}

const { post, posts } = Astro.props;
const { Content, headings } = await render(post);
const { relatedPosts, newerPost, olderPost } = await getPostPageData(post, posts);
---

<PostLayout
	post={post}
	headings={headings}
	relatedPosts={relatedPosts}
	newerPost={newerPost}
	olderPost={olderPost}
>
	<Content />
</PostLayout>
