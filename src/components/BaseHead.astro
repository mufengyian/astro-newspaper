---
import { hasPublicSiteUrl, siteConfig } from "../config";
import { getDictionary, getHrefLang, getOgLocale, resolveLocale } from "../utils/i18n";
import {
	getCanonicalPath,
	getLocaleAlternates,
	getRssPermalink,
	getSearchPermalink,
	withBase,
} from "../utils/routing";
import { getHtmlLang } from "../utils/i18n";
import { getThemeBootstrapScript } from "../utils/theme";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonical?: string;
	type?: "website" | "article";
	publishedTime?: Date;
	updatedTime?: Date;
	tags?: string[];
	section?: string;
}

const locale = resolveLocale(Astro.currentLocale);
const dictionary = getDictionary(locale);
const {
	title,
	description = dictionary.site.description,
	image,
	canonical,
	type = "website",
	publishedTime,
	updatedTime,
	tags = [],
	section,
} = Astro.props;

const pageTitle = title ? `${title} | ${siteConfig.title}` : `${siteConfig.title} | ${dictionary.site.tagline}`;
const publicSiteUrl = hasPublicSiteUrl() ? siteConfig.siteUrl : undefined;
const canonicalUrl = publicSiteUrl
	? canonical
		? new URL(canonical, publicSiteUrl).href
		: getCanonicalPath(locale, Astro.url.pathname)
	: undefined;
const wenkaiStylesheet =
	siteConfig.typography.preset === "wenkai"
		? (await import("../styles/wenkai.css?url")).default
		: undefined;
const socialImagePath = withBase(siteConfig.assets.socialCard);
const socialImage = publicSiteUrl ? new URL(image ?? socialImagePath, publicSiteUrl).href : undefined;
const alternateLocales = publicSiteUrl ? await getLocaleAlternates(Astro.url.pathname, locale) : [];
const xDefaultAlternateUrl =
	alternateLocales.find(({ locale: alternateLocale }) => alternateLocale === siteConfig.defaultLocale)
		?.absoluteUrl;
const rssFeedUrl = publicSiteUrl ? new URL(getRssPermalink(locale), publicSiteUrl).href : undefined;
const searchPageUrl = publicSiteUrl
	? new URL(`${getSearchPermalink(locale)}?q={search_term_string}`, publicSiteUrl).href
	: undefined;
const themeScript = getThemeBootstrapScript();
const socialImageAlt = title ?? siteConfig.title;
const languageTag = getHtmlLang(locale);

const structuredData =
	publicSiteUrl && type === "article" && title && publishedTime
		? {
				"@context": "https://schema.org",
				"@type": "BlogPosting",
				headline: title,
				description,
				...(socialImage ? { image: [socialImage] } : {}),
				datePublished: publishedTime.toISOString(),
				...(updatedTime ? { dateModified: updatedTime.toISOString() } : {}),
				author: {
					"@type": "Person",
					name: siteConfig.author.name,
				},
				publisher: {
					"@type": "Person",
					name: siteConfig.author.name,
				},
				mainEntityOfPage: canonicalUrl,
				inLanguage: languageTag,
				keywords: tags.join(", "),
			}
		: publicSiteUrl
			? {
					"@context": "https://schema.org",
					"@type": "WebSite",
					name: siteConfig.title,
					description,
					url: publicSiteUrl,
					inLanguage: languageTag,
					...(searchPageUrl
						? {
								potentialAction: {
									"@type": "SearchAction",
									target: searchPageUrl,
									"query-input": "required name=search_term_string",
								},
							}
						: {}),
				}
			: undefined;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author.name} />
<meta name="color-scheme" content="light dark" />
<meta name="theme-color" media="(prefers-color-scheme: light)" content={siteConfig.seo.themeColor.light} />
<meta name="theme-color" media="(prefers-color-scheme: dark)" content={siteConfig.seo.themeColor.dark} />
<link rel="icon" type="image/svg+xml" href={withBase(siteConfig.assets.faviconSvg)} />
<link rel="icon" href={withBase(siteConfig.assets.faviconIco)} />
{siteConfig.typography.preset === "wenkai" && <link rel="stylesheet" href={wenkaiStylesheet} />}
{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
{rssFeedUrl && <link rel="alternate" type="application/rss+xml" title={`${siteConfig.title} RSS`} href={rssFeedUrl} />}
{!publicSiteUrl && <meta name="robots" content="noindex, nofollow" />}

{canonicalUrl && <meta property="og:type" content={type} />}
{canonicalUrl && <meta property="og:title" content={pageTitle} />}
{canonicalUrl && <meta property="og:description" content={description} />}
{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
{socialImage && <meta property="og:image" content={socialImage} />}
{socialImage && <meta property="og:image:alt" content={socialImageAlt} />}
{canonicalUrl && <meta property="og:site_name" content={siteConfig.title} />}
{canonicalUrl && <meta property="og:locale" content={getOgLocale(locale)} />}

{canonicalUrl && <meta name="twitter:card" content="summary_large_image" />}
{canonicalUrl && <meta name="twitter:title" content={pageTitle} />}
{canonicalUrl && <meta name="twitter:description" content={description} />}
{socialImage && <meta name="twitter:image" content={socialImage} />}
{socialImage && <meta name="twitter:image:alt" content={socialImageAlt} />}

{publishedTime && canonicalUrl && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{updatedTime && canonicalUrl && <meta property="article:modified_time" content={updatedTime.toISOString()} />}
{type === "article" && canonicalUrl && <meta property="article:author" content={siteConfig.author.name} />}
{type === "article" && section && canonicalUrl && <meta property="article:section" content={section} />}
{canonicalUrl && tags.map((tag) => <meta property="article:tag" content={tag} />)}

{
	alternateLocales.map(({ locale: alternateLocale, absoluteUrl }) =>
		absoluteUrl ? <link rel="alternate" hreflang={getHrefLang(alternateLocale)} href={absoluteUrl} /> : null,
	)
}
{xDefaultAlternateUrl && <link rel="alternate" hreflang="x-default" href={xDefaultAlternateUrl} />}

<title>{pageTitle}</title>
<script is:inline set:html={themeScript}></script>
{structuredData && <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>}
