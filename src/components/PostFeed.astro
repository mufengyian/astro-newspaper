---
import type { PostEntry } from "../utils/posts";
import Pagination from "./Pagination.astro";
import PostCard from "./PostCard.astro";

interface Props {
	posts: PostEntry[];
	currentPage?: number;
	totalPages?: number;
	firstPageUrl?: string;
	pageUrlPattern?: string;
	variant?: "default" | "narrow";
}

const {
	posts,
	currentPage = 1,
	totalPages = 1,
	firstPageUrl = "/",
	pageUrlPattern = "/page/{page}",
	variant = "default",
} = Astro.props;
---

<section class:list={["posts-feed", variant === "narrow" && "posts-feed--narrow"]}>
	<div class:list={["posts-grid", variant === "narrow" && "posts-grid--narrow"]} data-posts-list>
		{posts.map((post) => (
			<PostCard post={post} />
		))}
	</div>

	<Pagination
		currentPage={currentPage}
		totalPages={totalPages}
		firstPageUrl={firstPageUrl}
		pageUrlPattern={pageUrlPattern}
	/>
</section>
