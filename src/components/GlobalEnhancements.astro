---
import BackToTop from "./BackToTop.astro";
import { getDictionary, resolveLocale } from "../utils/i18n";

const locale = resolveLocale(Astro.currentLocale);
const dictionary = getDictionary(locale);
---

<BackToTop />

<template
	data-copy-i18n
	data-copy-idle={dictionary.copy.idle}
	data-copy-success={dictionary.copy.success}
	data-copy-failure={dictionary.copy.failure}
></template>

<script>
	import { mountGlobalEnhancements } from "../scripts/global-enhancements";

	mountGlobalEnhancements();
</script>
