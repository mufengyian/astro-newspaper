---
import { formatDate } from "../utils/date";
import { getDictionary, type SiteLocale } from "../utils/i18n";
import { getPostPermalink, getReadingMinutes, type PostEntry } from "../utils/posts";

interface Props {
	locale: SiteLocale;
	groupedPosts: [number, PostEntry[]][];
}

const { locale, groupedPosts } = Astro.props;
const dictionary = getDictionary(locale);
---

<div class="archive-posts">
	{groupedPosts.map(([year, entries]) => (
		<section class="archive-year">
			<div class="archive-year__heading">
				<h2>{year}</h2>
				<span class="archive-count">{dictionary.archive.yearCount(entries.length)}</span>
			</div>

			<div class="archive-year__list">
				{entries.map((post) => (
					<article class="archive-entry">
						<div class="archive-entry__meta">
							<time datetime={post.data.publishDate.toISOString()}>
								{formatDate(post.data.publishDate, locale)}
							</time>
							<span aria-hidden="true">•</span>
							<span>{dictionary.reading.minutes(getReadingMinutes(post))}</span>
							{post.data.category && (
								<>
									<span aria-hidden="true">•</span>
									<span>{post.data.category}</span>
								</>
							)}
						</div>
						<h3 class="archive-entry-title">
							<a href={getPostPermalink(locale, post)} data-astro-prefetch="hover">
								{post.data.title}
							</a>
						</h3>
						<p>{post.data.excerpt}</p>
					</article>
				))}
			</div>
		</section>
	))}
</div>
